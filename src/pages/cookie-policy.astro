---
import SharedPageLayout from "../components/SharedPageLayout.astro";
---

<SharedPageLayout title="Cookie Policy | Done Deal Digital" bodyClass="bg-background-light font-dmsans text-navy">
    <Fragment slot="head">
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Work+Sans:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00",
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f6f8",
                        "background-dark": "#0B1D33",
                        "grid-gray": "rgba(255, 255, 255, 0.05)"
                    },
                    fontFamily: {
                        "display": ["Work Sans", "sans-serif"],
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "DEFAULT": "0",
                        "lg": "0",
                        "xl": "0",
                        "full": "9999px"
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image:
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 4px 4px 0px 0px rgba(11, 29, 51, 1);
            }
            .bebas-heavy {
                font-weight: 700;
                letter-spacing: 0.02em;
            }
        }
    </style>
</Fragment>

<section class="relative bg-navy py-16 border-b-2 border-navy overflow-hidden">
<div class="absolute inset-0 graph-paper opacity-30"></div>
<div class="max-w-5xl mx-auto px-6 relative z-10">
<div class="inline-block border-2 border-primary px-4 py-1 mb-4">
<span class="text-white font-bebas text-lg tracking-[.2em]">COOKIE POLICY</span>
</div>
<h1 class="font-bebas bebas-heavy text-5xl md:text-7xl text-white uppercase leading-none">
            This Cookie Policy explains cookies and similar technologies.
        </h1>
<p class="text-concrete/60 font-bold uppercase tracking-widest text-sm mt-4">Last Updated: March 11, 2026</p>
</div>
</section>

<main class="max-w-5xl mx-auto px-6 py-16">
<article class="bg-white border border-gray-300 p-8 md:p-12">
<h2 class="font-bebas bebas-heavy text-4xl text-navy mb-8">Cookie Policy</h2>
<p class="text-slate-700 leading-relaxed mb-10">
            This Cookie Policy explains what cookies or similar technologies this site uses, why we use them,
            and how they affect your visit.
        </p>

<section class="mb-10">
<h3 class="font-bebas text-2xl text-navy mb-4">CURRENT COOKIE USAGE</h3>
<p class="text-slate-700 leading-relaxed mb-4">
            Done Deal Digital keeps this site lean and does not run marketing or analytics scripts.
            Hosting and platform services may still set standard technical cookies required for delivery and security.
        </p>
<ul class="list-disc list-inside space-y-2 text-slate-700">
<li>Necessary infrastructure cookies for request handling and secure transport.</li>
<li>Optional browser settings and extensions may set additional cookies outside our control.</li>
</ul>
</section>

<section class="mb-10">
<h3 class="font-bebas text-2xl text-navy mb-4">MANAGING COOKIES</h3>
<ul class="list-disc list-inside space-y-2 text-slate-700">
<li>Most browsers let you clear cookies and block new cookies from a site.</li>
<li>Blocking cookies may affect form submission and embedded tools.</li>
<li>Use your browser privacy settings if you want stricter control.</li>
</ul>
</section>

<section>
<h3 class="font-bebas text-2xl text-navy mb-4">CHANGES</h3>
<p class="text-slate-700 leading-relaxed">
            If we add tracking technologies in the future, this page will be updated and dated.
        </p>
<p class="text-slate-700 leading-relaxed mt-4">
            Questions about cookies or data handling can be directed to <strong>hello@donedealdigital.com</strong>.
        </p>
</section>
</article>
</main>

</SharedPageLayout>
