---
import "../styles/global.css";

import SharedPageLayout from "../components/SharedPageLayout.astro";
---

<SharedPageLayout title="Done Deal Digital | Websites and Local Lead Systems for the Trades" bodyClass="page">
    <Fragment slot="head">
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=Work+Sans:wght@400;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    </Fragment>


    <section id="hero" class="hero">
      <div class="hero__bg u-graph-paper"></div>
      <div class="hero__inner site-container">
        <div class="hero__content">
          <h1 class="hero__headline">
            WE BUILD WEBSITES THAT
            <span class="hero__headline-accent">WORK AS HARD</span>
            AS YOU DO.
          </h1>
          <p class="hero__copy">
            We build websites first, then support local SEO and paid ads when they fit.
            The goal is simple: help the right customer trust you fast and take the next step.
          </p>
            <div class="hero__actions">
            <a class="hero__cta cta cta--accent cta--md" href="/contact">GET A FREE QUOTE</a>
          </div>
        </div>

        <div class="hero__media">
          <div class="hero__media-frame u-block-shadow--accent">
            <div class="hero__media-inner">
              <img
                alt="Professional electrician working"
                class="hero__media-image u-bw"
                src="/images/Gemini_Generated_Image_dvy1dodvy1dodvy1.png"
              />
              <div class="hero__media-overlay"></div>
            </div>
          </div>
          <div class="hero__badge">
            <p class="hero__badge-copy">Consider it...</p>
            <p class="hero__badge-title">Done.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="credibility" class="cred-strip">
      <div class="cred-strip__inner">
            <div class="cred-strip__item">
              <span class="cred-strip__icon material-symbols-outlined" aria-hidden="true">storefront</span>
              <span class="cred-strip__text">Built for trades</span>
            </div>
            <div class="cred-strip__divider"></div>
            <div class="cred-strip__item">
              <span class="cred-strip__icon material-symbols-outlined" aria-hidden="true">calendar_month</span>
              <span class="cred-strip__text">Clear scope upfront</span>
            </div>
            <div class="cred-strip__divider"></div>
            <div class="cred-strip__item">
              <span class="cred-strip__icon material-symbols-outlined" aria-hidden="true">dashboard</span>
              <span class="cred-strip__text">Mobile-first pages</span>
            </div>
            <div class="cred-strip__divider"></div>
            <div class="cred-strip__item">
              <span class="cred-strip__icon material-symbols-outlined" aria-hidden="true">bolt</span>
              <span class="cred-strip__text">Calls over vanity metrics</span>
            </div>
          </div>
    </section>

        <section id="services" class="services">
      <div class="site-container">
          <div class="services__heading">
            <h2 class="services__title">NO FLUFF. JUST RESULTS.</h2>
            <div class="services__rule"></div>
          </div>
        <div class="services__list">
          <a class="services-card" href="/web-design" aria-label="Learn more about Web Design services">
            <div class="services-card__icon-wrap">
              <span class="services-card__icon material-symbols-outlined">monitor</span>
            </div>
            <h3 class="services-card__title">WEB DESIGN</h3>
            <p class="services-card__description">
              Websites for small businesses, built to look credible fast and turn visits into calls.
            </p>
            <p class="services-card__followup">Looks sharp. Loads fast. Gets the phone ringing.</p>
          </a>
          <a class="services-card" href="/local-seo" aria-label="Learn more about Local SEO services">
            <div class="services-card__icon-wrap">
              <span class="services-card__icon material-symbols-outlined">trending_up</span>
            </div>
            <h3 class="services-card__title">LOCAL SEO</h3>
              <p class="services-card__description">
                Local SEO for businesses that need to show up more clearly in Google Maps and local search.
              </p>
            <p class="services-card__followup">Google Maps, search results, review profiles — all dialed in.</p>
          </a>
          <a class="services-card" href="/lead-generation" aria-label="Learn more about Lead Generation services">
            <div class="services-card__icon-wrap">
              <span class="services-card__icon material-symbols-outlined">target</span>
            </div>
            <h3 class="services-card__title">LEAD GEN</h3>
              <p class="services-card__description">
                Paid ads for operators who can answer fast, track leads, and support the spend.
              </p>
            <p class="services-card__followup">Targeted clicks, tracked calls, real ROI you can see.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="home-frustrations">
      <div class="site-container home-frustrations__inner">
        <h2 class="home-frustrations__title">Why Owners Come to Us</h2>
        <div class="home-frustrations-grid">
          <article class="home-frustrations-card">
            <span class="home-frustrations-card__icon material-symbols-outlined" aria-hidden="true">cancel</span>
            <p class="home-frustrations-quote">"My site looks dated and I&apos;m not getting enough calls."</p>
            <p class="home-frustrations-copy">We rebuild the pages, tighten the message, and give people a clearer reason to contact you.</p>
          </article>
          <article class="home-frustrations-card">
            <span class="home-frustrations-card__icon material-symbols-outlined" aria-hidden="true">visibility_off</span>
            <p class="home-frustrations-quote">"People know my name, but I&apos;m hard to find on Google."</p>
            <p class="home-frustrations-copy">We fix the local basics first so your business shows up more clearly in the markets you serve.</p>
          </article>
          <article class="home-frustrations-card">
            <span class="home-frustrations-card__icon material-symbols-outlined" aria-hidden="true">monetization_on</span>
            <p class="home-frustrations-quote">"I&apos;m spending on ads, but I can&apos;t tell what&apos;s working."</p>
            <p class="home-frustrations-copy">We track calls, forms, and lead quality so you can judge the spend like an owner.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="process" class="process home-process">
      <span id="proof" class="site-proof-anchor">Proof section target</span>
      <div class="process__inner site-container">
        <div class="process__grid">
          <div class="process__copy">
            <h2 class="process__title">THE DONE DEAL PROCESS</h2>
            <div class="process__steps">
              <div class="process-step">
                <div class="process-step__number">01</div>
                <div class="process-step__body">
                  <h4 class="process-step__title">CONSULTATION</h4>
                  <p class="process-step__copy">
                    We analyze your current digital presence and your local competitors to build a custom roadmap.
                  </p>
                </div>
              </div>
              <div class="process-step">
                <div class="process-step__number">02</div>
                <div class="process-step__body">
                  <h4 class="process-step__title">BUILD</h4>
                  <p class="process-step__copy">
                    Our team builds your high-converting assets and launches your targeted marketing campaigns.
                  </p>
                </div>
              </div>
              <div class="process-step">
                <div class="process-step__number">03</div>
                <div class="process-step__body">
                  <h4 class="process-step__title">GROWTH</h4>
                  <p class="process-step__copy">
                    We continually monitor and optimize your campaigns, sharing weekly and monthly reports so you know what&apos;s working.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="process__gallery">
            <div class="process-gallery__cell">
              <div class="process-gallery__frame">
                <img
                  alt="HVAC technician"
                  class="process-gallery__image u-bw"
                  src="/images/meatlaptop.png"
                />
                <div class="process-gallery__overlay"></div>
              </div>
            </div>
            <div class="process-gallery__cell process-gallery__cell--offset">
              <div class="process-gallery__frame">
                <img
                  alt="Holding a phone while servicing"
                  class="process-gallery__image u-bw"
                  src="/images/holdingphone.png"
                />
                <div class="process-gallery__overlay"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

        <section class="home-faq">
          <div class="site-container">
            <div class="home-faq__title-wrap">
              <h2 class="home-faq__title">
                <span class="home-faq__title-accent">STRAIGHT ANSWERS</span> BEFORE YOU REACH OUT
              </h2>
            </div>
            <ul class="home-faq__list">
          <li class="home-faq__entry">
            <span class="home-faq__number">01</span>
            <div>
              <h3 class="home-faq__question">Do I need a new website, or can you improve the one I have?</h3>
              <p class="home-faq__answer">We can do either. If your current site is worth keeping, we’ll say so. If a rebuild is the cleaner move, we’ll explain why.</p>
            </div>
          </li>
          <li class="home-faq__entry">
            <span class="home-faq__number">02</span>
            <div>
              <h3 class="home-faq__question">How much does a website project usually cost?</h3>
              <p class="home-faq__answer">Pricing depends on scope, page count, and whether we’re rebuilding or starting fresh. We quote website projects at a fixed project fee once scope is clear.</p>
            </div>
          </li>
          <li class="home-faq__entry">
            <span class="home-faq__number">03</span>
            <div>
              <h3 class="home-faq__question">How long does a project take?</h3>
              <p class="home-faq__answer">Most website projects launch in about 2 to 3 weeks once we have the needed photos, details, and feedback.</p>
            </div>
          </li>
          <li class="home-faq__entry">
            <span class="home-faq__number">04</span>
            <div>
              <h3 class="home-faq__question">Do I own the website and accounts?</h3>
              <p class="home-faq__answer">Yes. You should own your website, domain, and primary accounts. We make that clear in the agreement and handoff.</p>
            </div>
          </li>
          <li class="home-faq__entry">
            <span class="home-faq__number">05</span>
            <div>
              <h3 class="home-faq__question">Is web design the right first step, or do I need SEO or ads first?</h3>
              <p class="home-faq__answer">For most businesses, the website is the first move. If traffic is landing on a weak site, SEO and ads get less efficient.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

      <section id="contact" class="final-cta">
      <div class="final-cta__wrap">
        <div class="final-cta__panel">
          <div class="final-cta__text">
            <h2 class="final-cta__title">READY FOR A SITE THAT EARNS ITS KEEP?</h2>
            <p class="final-cta__copy">
              If the site is the problem, we’ll tell you. If it isn’t, we’ll tell you that too.
            </p>
            <div class="final-cta__actions">
              <a class="final-cta__button cta cta--accent cta--xl" href="/contact">GET A FREE QUOTE</a>
            </div>
          </div>
        </div>
      </div>
    </section>
</SharedPageLayout>
