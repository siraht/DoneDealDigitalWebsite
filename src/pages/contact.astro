---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Contact Done Deal Digital | Get A Quote</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Work+Sans:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00", // Construction Orange
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f6f8",
                        "background-dark": "#0B1D33",
                        "grid-gray": "rgba(255, 255, 255, 0.05)"
                    },
                    fontFamily: {
                        "display": ["Work Sans", "sans-serif"],
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "DEFAULT": "0",
                        "lg": "0",
                        "xl": "0",
                        "full": "9999px"
                    },
                    borderWidth: {
                        "3": "3px"
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image: 
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 6px 6px 0px 0px rgba(11, 29, 51, 1);
            }
            .block-shadow-orange {
                box-shadow: 6px 6px 0px 0px #FF7B00;
            }
            .diagonal-stripes {
                background-image: repeating-linear-gradient(45deg, rgba(11, 29, 51, 0.03) 0, rgba(11, 29, 51, 0.03) 10px, transparent 10px, transparent 20px);
            }
        }
        .bebas-heavy {
            font-weight: 700;
            letter-spacing: 0.02em;
        }
        input, select, textarea {
            border-radius: 0 !important;
            border: 2px solid #0B1D33 !important;
        }
        input:focus, select:focus, textarea:focus {
            --tw-ring-color: #FF7B00 !important;
            border-color: #FF7B00 !important;
        }
    </style>
</head>
<body class="bg-concrete font-dmsans text-navy">
<SiteHeader />
<section class="relative bg-navy overflow-hidden border-b-2 border-navy">
<div class="absolute inset-0 graph-paper opacity-40"></div>
<div class="max-w-7xl mx-auto px-6 lg:px-20 py-20 relative z-10">
<div class="max-w-3xl">
<h1 class="font-bebas bebas-heavy text-7xl md:text-8xl text-white leading-[0.85] uppercase mb-6">
                TELL US WHAT <span class="text-primary">YOU NEED.</span>
</h1>
<p class="text-concrete text-xl md:text-2xl leading-relaxed font-medium">
                Fill out the form and we’ll get back to you within 1 business day. <br class="hidden md:block"/>No pushy sales routine.
            </p>
</div>
</div>
</section>
<main class="relative diagonal-stripes">
<div class="max-w-7xl mx-auto px-6 lg:px-20 py-16">
<div class="grid lg:grid-cols-3 gap-12 items-start">
<div class="lg:col-span-2">
<div class="bg-white border-2 border-navy p-8 md:p-12 block-shadow">
<form action="#" class="space-y-8">
<div class="grid md:grid-cols-2 gap-8">
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">Full Name</label>
<input class="w-full p-4 font-medium" placeholder="John Doe" required="" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">Business Name</label>
<input class="w-full p-4 font-medium" placeholder="Doe's Plumbing Co." required="" type="text"/>
</div>
</div>
<div class="grid md:grid-cols-2 gap-8">
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">Phone Number</label>
<input class="w-full p-4 font-medium" placeholder="(555) 000-0000" required="" type="tel"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">Email Address</label>
<input class="w-full p-4 font-medium" placeholder="john@example.com" required="" type="email"/>
</div>
</div>
<div class="grid md:grid-cols-2 gap-8">
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">Website URL (Optional)</label>
<input class="w-full p-4 font-medium" placeholder="www.yourbusiness.com" type="url"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">City / Service Area</label>
<input class="w-full p-4 font-medium" placeholder="e.g. Dallas, TX" required="" type="text"/>
</div>
</div>
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">What do you need?</label>
<select class="w-full p-4 font-medium bg-white">
<option>New Website Design</option>
<option>Local SEO / Google Maps</option>
<option>Paid Lead Generation</option>
<option>Full Digital Overhaul</option>
<option>Other</option>
</select>
</div>
<div class="flex flex-col gap-2">
<label class="font-bold uppercase text-xs tracking-widest text-navy/60">Anything Else?</label>
<textarea class="w-full p-4 font-medium" placeholder="Tell us a bit about your project goals..." rows="4"></textarea>
</div>
<button class="w-full md:w-auto bg-primary hover:bg-orange-600 text-white px-12 py-6 font-bebas bebas-heavy text-3xl uppercase tracking-widest transition-all border-2 border-navy block-shadow-orange" type="submit">
                            GET MY QUOTE
                        </button>
</form>
</div>
</div>
<div class="space-y-8">
<div class="bg-navy border-2 border-navy p-8 block-shadow-orange text-white">
<h3 class="font-bebas bebas-heavy text-4xl mb-6 text-primary uppercase">Quick Contact</h3>
<div class="space-y-8">
<a class="group flex items-center gap-4" href="tel:5551234567">
<div class="bg-primary p-3 border-2 border-white group-hover:scale-105 transition-transform">
<span class="material-symbols-outlined text-3xl leading-none">phone_in_talk</span>
</div>
<div>
<p class="text-xs font-bold uppercase tracking-widest text-concrete/60">Call Us Directly</p>
<p class="text-xl font-bold">(555) 123-4567</p>
</div>
</a>
<a class="group flex items-center gap-4" href="mailto:hello@donedealdigital.com">
<div class="bg-white text-navy p-3 border-2 border-primary group-hover:scale-105 transition-transform">
<span class="material-symbols-outlined text-3xl leading-none">mail</span>
</div>
<div>
<p class="text-xs font-bold uppercase tracking-widest text-concrete/60">Email Our Team</p>
<p class="text-xl font-bold">hello@donedealdigital.com</p>
</div>
</a>
</div>
<div class="mt-12 pt-8 border-t border-white/10">
<div class="flex gap-3 items-start">
<span class="material-symbols-outlined text-primary">schedule</span>
<p class="text-concrete text-sm leading-relaxed">
<span class="block font-bold text-white uppercase mb-1">Response Time</span>
                                We typically reply within 1 business day. If it’s urgent, call us.
                            </p>
</div>
</div>
</div>
<div class="border-2 border-navy p-6 bg-white flex flex-col items-center text-center">
<span class="material-symbols-outlined text-5xl text-navy mb-4">verified_user</span>
<h4 class="font-bebas bebas-heavy text-2xl uppercase">No Sales Games</h4>
<p class="text-sm text-slate-600">We don't do high-pressure sales. We're here to see if we're a good fit for your business.</p>
</div>
</div>
</div>
</div>
</main>
<SiteFooter />

</body></html>
