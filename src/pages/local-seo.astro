---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Local SEO Services | Done Deal Digital</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Work+Sans:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00", // Construction Orange
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f6f8",
                        "background-dark": "#0B1D33"
                    },
                    fontFamily: {
                        "display": ["Work Sans", "sans-serif"],
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "DEFAULT": "0",
                        "lg": "0"
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image: 
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 6px 6px 0px 0px rgba(11, 29, 51, 1);
            }
            .block-shadow-orange {
                box-shadow: 6px 6px 0px 0px #FF7B00;
            }
            .bw-overlay {
                filter: grayscale(1) contrast(1.2);
            }
            .industrial-border {
                border: 2px solid #0B1D33;
            }
        }
        .bebas-heavy {
            font-weight: 700;
            letter-spacing: 0.02em;
        }
    </style>
</head>
<body class="bg-background-light font-dmsans text-navy">
<SiteHeader />
<section class="relative bg-navy overflow-hidden border-b-2 border-navy">
<div class="absolute inset-0 graph-paper opacity-40"></div>
<div class="max-w-7xl mx-auto px-6 lg:px-20 py-24 lg:py-32 relative z-10">
<div class="max-w-4xl">
<div class="inline-block border-4 border-primary p-4 mb-8">
<span class="text-white font-bebas bebas-heavy text-2xl tracking-[.2em]">DOMINATE LOCAL SEARCH</span>
</div>
<h1 class="font-bebas bebas-heavy text-7xl md:text-9xl text-white leading-[0.85] uppercase mb-8">
                GET FOUND BY LOCAL CUSTOMERS <span class="text-primary">WHO NEED YOU.</span>
</h1>
<p class="text-concrete text-xl md:text-2xl max-w-2xl leading-relaxed font-medium mb-12">
                When someone nearby searches for the service you do, your business needs to be the first one they see. We put your trucks in front of their eyes.
            </p>
<div class="flex flex-wrap gap-6">
<button class="bg-primary text-white px-10 py-5 font-bold text-lg uppercase tracking-widest border-2 border-navy block-shadow-orange">
                    GET A FREE SEO REVIEW
                </button>
</div>
</div>
</div>
</section>
<section class="py-24 bg-white border-b-2 border-navy">
<div class="max-w-7xl mx-auto px-6">
<div class="grid md:grid-cols-2 gap-0 border-2 border-navy">
<div class="p-12 border-b-2 md:border-b-0 md:border-r-2 border-navy">
<h3 class="font-bebas bebas-heavy text-5xl text-navy mb-8 flex items-center gap-4">
<span class="material-symbols-outlined text-green-600 text-5xl">check_circle</span>
                    BEST FIT
                </h3>
<ul class="space-y-6">
<li class="flex items-start gap-4 text-xl font-bold uppercase tracking-tight">
<span class="material-symbols-outlined text-primary mt-1">arrow_forward</span>
                        Established Trades (Plumbing, Roofing, HVAC)
                    </li>
<li class="flex items-start gap-4 text-xl font-bold uppercase tracking-tight">
<span class="material-symbols-outlined text-primary mt-1">arrow_forward</span>
                        Physical Office or Service Area Businesses
                    </li>
<li class="flex items-start gap-4 text-xl font-bold uppercase tracking-tight">
<span class="material-symbols-outlined text-primary mt-1">arrow_forward</span>
                        Ready to handle 5-10 new calls per week
                    </li>
</ul>
</div>
<div class="p-12 bg-concrete/30">
<h3 class="font-bebas bebas-heavy text-5xl text-navy mb-8 flex items-center gap-4">
<span class="material-symbols-outlined text-red-600 text-5xl">cancel</span>
                    POOR FIT
                </h3>
<ul class="space-y-6">
<li class="flex items-start gap-4 text-xl font-bold uppercase tracking-tight opacity-70">
<span class="material-symbols-outlined text-navy/40 mt-1">close</span>
                        E-commerce or National-only brands
                    </li>
<li class="flex items-start gap-4 text-xl font-bold uppercase tracking-tight opacity-70">
<span class="material-symbols-outlined text-navy/40 mt-1">close</span>
                        Side-hustlers without a business license
                    </li>
<li class="flex items-start gap-4 text-xl font-bold uppercase tracking-tight opacity-70">
<span class="material-symbols-outlined text-navy/40 mt-1">close</span>
                        Businesses that don't answer the phone
                    </li>
</ul>
</div>
</div>
</div>
</section>
<section class="py-24 bg-background-light">
<div class="max-w-7xl mx-auto px-6">
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-16 text-center">WHAT LOCAL SEO <span class="text-primary">ACTUALLY IS</span></h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
<div class="border-2 border-navy bg-white p-8 block-shadow relative">
<div class="absolute -top-4 -left-4 bg-navy text-white px-4 py-1 font-bebas text-xl">STEP 01</div>
<h4 class="font-bebas text-3xl mb-4">BUSINESS INFO</h4>
<p class="text-sm font-bold text-navy/70 uppercase">Consistent NAP (Name, Address, Phone) data across the entire web.</p>
</div>
<div class="border-2 border-navy bg-white p-8 block-shadow relative">
<div class="absolute -top-4 -left-4 bg-navy text-white px-4 py-1 font-bebas text-xl">STEP 02</div>
<h4 class="font-bebas text-3xl mb-4">GBP SIGNALS</h4>
<p class="text-sm font-bold text-navy/70 uppercase">Optimizing your Google Business Profile for the Map Pack.</p>
</div>
<div class="border-2 border-navy bg-white p-8 block-shadow relative">
<div class="absolute -top-4 -left-4 bg-navy text-white px-4 py-1 font-bebas text-xl">STEP 03</div>
<h4 class="font-bebas text-3xl mb-4">SERVICE PAGES</h4>
<p class="text-sm font-bold text-navy/70 uppercase">Content designed to rank for specific trades in specific towns.</p>
</div>
<div class="border-2 border-navy bg-white p-8 block-shadow relative">
<div class="absolute -top-4 -left-4 bg-navy text-white px-4 py-1 font-bebas text-xl">STEP 04</div>
<h4 class="font-bebas text-3xl mb-4">REVIEW QUALITY</h4>
<p class="text-sm font-bold text-navy/70 uppercase">Velocity and sentiment of local customer feedback.</p>
</div>
<div class="border-2 border-navy bg-white p-8 block-shadow relative">
<div class="absolute -top-4 -left-4 bg-navy text-white px-4 py-1 font-bebas text-xl">STEP 05</div>
<h4 class="font-bebas text-3xl mb-4">TRUST SIGNALS</h4>
<p class="text-sm font-bold text-navy/70 uppercase">Backlinks from local organizations and trade associations.</p>
</div>
<div class="border-2 border-navy bg-white p-8 block-shadow relative">
<div class="absolute -top-4 -left-4 bg-navy text-white px-4 py-1 font-bebas text-xl">STEP 06</div>
<h4 class="font-bebas text-3xl mb-4">MEASUREMENT</h4>
<p class="text-sm font-bold text-navy/70 uppercase">Tracking calls and leads, not just "vanity" rankings.</p>
</div>
</div>
</div>
</section>
<section class="py-24 bg-navy text-white relative border-y-4 border-primary">
<div class="absolute inset-0 graph-paper opacity-20"></div>
<div class="max-w-7xl mx-auto px-6 relative z-10">
<h2 class="font-bebas bebas-heavy text-7xl mb-16">WHAT WE <span class="text-primary">FIX FIRST</span></h2>
<div class="space-y-4">
<div class="group flex items-center border-2 border-white/20 hover:border-primary transition-colors cursor-default">
<span class="font-bebas text-8xl px-8 text-primary/50 group-hover:text-primary transition-colors">1</span>
<div class="py-8 pr-8">
<h3 class="font-bebas text-4xl mb-2">DUPLICATE LISTINGS</h3>
<p class="text-concrete/60 font-bold uppercase tracking-widest text-sm">Confusing Google is the fastest way to get buried.</p>
</div>
</div>
<div class="group flex items-center border-2 border-white/20 hover:border-primary transition-colors cursor-default">
<span class="font-bebas text-8xl px-8 text-primary/50 group-hover:text-primary transition-colors">2</span>
<div class="py-8 pr-8">
<h3 class="font-bebas text-4xl mb-2">KEYWORD STUFFING</h3>
<p class="text-concrete/60 font-bold uppercase tracking-widest text-sm">Cleaning up spammy titles that risk profile suspension.</p>
</div>
</div>
<div class="group flex items-center border-2 border-white/20 hover:border-primary transition-colors cursor-default">
<span class="font-bebas text-8xl px-8 text-primary/50 group-hover:text-primary transition-colors">3</span>
<div class="py-8 pr-8">
<h3 class="font-bebas text-4xl mb-2">BROKEN LINKS</h3>
<p class="text-concrete/60 font-bold uppercase tracking-widest text-sm">Ensuring every 'Get Quote' button actually works.</p>
</div>
</div>
<div class="group flex items-center border-2 border-white/20 hover:border-primary transition-colors cursor-default">
<span class="font-bebas text-8xl px-8 text-primary/50 group-hover:text-primary transition-colors">4</span>
<div class="py-8 pr-8">
<h3 class="font-bebas text-4xl mb-2">IMAGE METADATA</h3>
<p class="text-concrete/60 font-bold uppercase tracking-widest text-sm">Geotagging your job site photos for local relevance.</p>
</div>
</div>
<div class="group flex items-center border-2 border-white/20 hover:border-primary transition-colors cursor-default">
<span class="font-bebas text-8xl px-8 text-primary/50 group-hover:text-primary transition-colors">5</span>
<div class="py-8 pr-8">
<h3 class="font-bebas text-4xl mb-2">RESPONSE TIME</h3>
<p class="text-concrete/60 font-bold uppercase tracking-widest text-sm">Setting up automated review requests to build social proof.</p>
</div>
</div>
</div>
</div>
</section>
<section class="py-24 bg-white">
<div class="max-w-7xl mx-auto px-6">
<div class="grid md:grid-cols-3 gap-10">
<div class="p-10 border-4 border-navy block-shadow">
<span class="material-symbols-outlined text-primary text-5xl mb-6">map</span>
<h3 class="font-bebas text-4xl mb-4">GBP FOUNDATION</h3>
<p class="font-bold uppercase text-sm text-navy/60 leading-relaxed">Map pack dominance through verified data and active profile management.</p>
</div>
<div class="p-10 border-4 border-navy block-shadow-orange">
<span class="material-symbols-outlined text-primary text-5xl mb-6">article</span>
<h3 class="font-bebas text-4xl mb-4">ON-PAGE SEO</h3>
<p class="font-bold uppercase text-sm text-navy/60 leading-relaxed">Hard-hitting service pages that rank for high-intent trade keywords.</p>
</div>
<div class="p-10 border-4 border-navy block-shadow">
<span class="material-symbols-outlined text-primary text-5xl mb-6">link</span>
<h3 class="font-bebas text-4xl mb-4">CITATIONS</h3>
<p class="font-bold uppercase text-sm text-navy/60 leading-relaxed">Syncing your business across 100+ high-authority local directories.</p>
</div>
</div>
</div>
</section>
<section class="py-24 bg-concrete">
<div class="max-w-4xl mx-auto px-6">
<div class="border-t-8 border-navy pt-12">
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-12">WHAT WE <span class="text-primary">WILL NOT DO</span></h2>
<div class="bg-white border-2 border-navy p-12 block-shadow">
<div class="flex items-center gap-4 mb-8">
<span class="bg-navy text-white px-4 py-1 font-bebas text-2xl uppercase">NO BS POLICY</span>
</div>
<ul class="space-y-8">
<li class="flex items-center gap-6 border-b border-navy/10 pb-6 last:border-0">
<span class="material-symbols-outlined text-red-600 font-bold">block</span>
<span class="font-bold text-xl uppercase tracking-tighter">WE WILL NOT sell you "guaranteed #1" overnight rankings.</span>
</li>
<li class="flex items-center gap-6 border-b border-navy/10 pb-6 last:border-0">
<span class="material-symbols-outlined text-red-600 font-bold">block</span>
<span class="font-bold text-xl uppercase tracking-tighter">WE WILL NOT hide our work behind locked dashboards.</span>
</li>
<li class="flex items-center gap-6 border-b border-navy/10 pb-6 last:border-0">
<span class="material-symbols-outlined text-red-600 font-bold">block</span>
<span class="font-bold text-xl uppercase tracking-tighter">WE WILL NOT use black-hat bots that get you banned.</span>
</li>
<li class="flex items-center gap-6 border-b border-navy/10 pb-6 last:border-0">
<span class="material-symbols-outlined text-red-600 font-bold">block</span>
<span class="font-bold text-xl uppercase tracking-tighter">WE WILL NOT charge for reports you don't understand.</span>
</li>
</ul>
</div>
</div>
</div>
</section>
<section class="py-24 bg-white border-b-2 border-navy overflow-hidden">
<div class="max-w-7xl mx-auto px-6">
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-4 text-center">COMPOUNDING GROWTH</h2>
<p class="text-center font-bold uppercase text-navy/60 mb-16 tracking-widest">EXPECTED TIMELINE FOR DOMINANCE</p>
<div class="relative h-80 border-l-4 border-b-4 border-navy mt-20">
<div class="absolute bottom-0 left-0 w-full h-full flex items-end">
<div class="w-1/4 h-[20%] bg-navy/10 border-t-2 border-navy flex items-center justify-center relative">
<span class="absolute -top-10 font-bebas text-xl">DAYS 0-30</span>
<span class="text-[10px] font-bold uppercase rotate-90 md:rotate-0">Foundation</span>
</div>
<div class="w-1/4 h-[45%] bg-navy/20 border-t-2 border-navy flex items-center justify-center relative">
<span class="absolute -top-10 font-bebas text-xl">DAYS 30-60</span>
<span class="text-[10px] font-bold uppercase rotate-90 md:rotate-0">Indexing</span>
</div>
<div class="w-1/4 h-[75%] bg-primary/40 border-t-4 border-primary flex items-center justify-center relative">
<span class="absolute -top-10 font-bebas text-xl text-primary">DAYS 60-120</span>
<span class="text-[10px] font-bold uppercase rotate-90 md:rotate-0">Velocity</span>
</div>
<div class="w-1/4 h-[100%] bg-primary border-t-4 border-navy flex items-center justify-center relative">
<span class="absolute -top-10 font-bebas text-xl text-primary font-bold">SCALING</span>
<span class="text-white text-[10px] font-bold uppercase rotate-90 md:rotate-0">Market Leader</span>
</div>
</div>
<div class="absolute -left-12 top-0 h-full flex flex-col justify-between py-2">
<span class="font-bebas text-navy/40">HIGH</span>
<span class="font-bebas text-navy/40">LEADS</span>
<span class="font-bebas text-navy/40">LOW</span>
</div>
</div>
</div>
</section>
<section class="py-24 bg-background-light">
<div class="max-w-5xl mx-auto px-6">
<div class="bg-navy p-12 relative border-4 border-primary block-shadow">
<div class="text-center">
<h2 class="font-bebas bebas-heavy text-7xl text-white mb-6 uppercase">READY TO BE EASIER TO FIND?</h2>
<p class="text-2xl text-concrete/80 mb-12 max-w-2xl mx-auto font-medium">Get a detailed breakdown of how your competitors are beating you—and how we'll fix it.</p>
<button class="bg-primary hover:bg-orange-600 text-white px-12 py-6 font-bold text-2xl uppercase tracking-widest border-2 border-white block-shadow-orange w-full md:w-auto">
                    GET MY FREE SEO AUDIT
                </button>
</div>
</div>
</div>
</section>
<SiteFooter />

</body></html>
