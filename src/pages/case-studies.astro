---
import SharedPageLayout from "../components/SharedPageLayout.astro";
---

<SharedPageLayout title="Case Studies | Done Deal Digital" bodyClass="bg-background-light font-dmsans text-navy">
    <Fragment slot="head">
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Work+Sans:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00",
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f8fb",
                        "background-dark": "#0B1D33",
                    },
                    fontFamily: {
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "lg": "0",
                        "xl": "0",
                        "full": "9999px"
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image:
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 6px 6px 0px 0px rgba(11, 29, 51, 1);
            }
            .block-shadow-orange {
                box-shadow: 6px 6px 0px 0px #FF7B00;
            }
            .diagonal-stripes {
                background-image: repeating-linear-gradient(45deg, rgba(11, 29, 51, 0.05) 0, rgba(11, 29, 51, 0.05) 10px, transparent 10px, transparent 20px);
            }
        }
        .bebas-heavy {
            font-weight: 700;
            letter-spacing: 0.02em;
        }
    </style>
</Fragment>

<section class="relative bg-navy py-24 overflow-hidden border-b-2 border-navy">
<div class="absolute inset-0 graph-paper opacity-40"></div>
<div class="max-w-7xl mx-auto px-6 relative z-10">
<div class="max-w-3xl">
<h1 class="font-bebas bebas-heavy text-7xl md:text-8xl text-white leading-none mb-6">
                PROOF, <span class="text-primary">NOT PROMISES.</span>
            </h1>
<p class="text-concrete text-2xl font-medium leading-relaxed max-w-2xl">
                This page is not public until client outcomes are approved for distribution. We prefer to publish only finished, verified results.
            </p>
</div>
</div>
</section>

<section class="py-24 bg-white">
<div class="max-w-5xl mx-auto px-6">
<div class="border-4 border-navy bg-background-light p-10 md:p-16 relative">
<div class="absolute -top-6 left-6 bg-primary px-6 py-2 border-2 border-navy">
<span class="font-bebas bebas-heavy text-2xl text-white uppercase tracking-widest">COMING SOON</span>
</div>
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-8 mt-4">HOW CASE STUDIES WILL BE SHARED</h2>
<p class="text-xl text-slate-600 mb-12 max-w-3xl">
                When case studies are published, we’ll show each project with a clear structure:
            </p>
<div class="grid md:grid-cols-3 gap-6 mb-8">
<div class="bg-white border-2 border-navy p-6">
<h3 class="font-bebas bebas-heavy text-3xl text-navy uppercase">WHERE IT STARTED</h3>
<p class="text-sm font-bold uppercase tracking-widest text-slate-500 mt-4">
                        Baseline calls, lead quality, and process gaps.
                    </p>
</div>
<div class="bg-white border-2 border-navy p-6">
<h3 class="font-bebas bebas-heavy text-3xl text-navy uppercase">WHAT WE CHANGED</h3>
<p class="text-sm font-bold uppercase tracking-widest text-slate-500 mt-4">
                        Scope, structure, tracking, and messaging adjustments.
                    </p>
</div>
<div class="bg-white border-2 border-navy p-6">
<h3 class="font-bebas bebas-heavy text-3xl text-navy uppercase">RESULTS</h3>
<p class="text-sm font-bold uppercase tracking-widest text-slate-500 mt-4">
                        Verified movement in calls, workload fit, and reporting clarity.
                    </p>
</div>
</div>
<p class="text-lg text-slate-700">
                If you’d like to discuss prior work relevant to your business, contact us directly.
            </p>
</div>
</div>
</section>

<section class="py-24 bg-background-light">
<div class="max-w-5xl mx-auto px-6">
<div class="border-4 border-navy p-12 text-center bg-white block-shadow">
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-8">READY TO BE OUR NEXT PROJECT?</h2>
<p class="text-2xl text-slate-600 mb-12 max-w-2xl mx-auto">
                We’ll evaluate your fit and recommend the next best step for your business goals.
            </p>
<a href="/contact" class="inline-block bg-primary hover:bg-orange-600 text-white px-12 py-6 font-bold text-2xl uppercase tracking-widest border-2 border-navy block-shadow-orange transition-transform hover:-translate-y-1">
                LET'S TALK
            </a>
</div>
</div>
</section>

</SharedPageLayout>
