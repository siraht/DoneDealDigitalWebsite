---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Case Studies | Done Deal Digital</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00",
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f6f8",
                        "background-dark": "#0B1D33",
                    },
                    fontFamily: {
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "DEFAULT": "0",
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image: 
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 6px 6px 0px 0px rgba(11, 29, 51, 1);
            }
            .block-shadow-orange {
                box-shadow: 6px 6px 0px 0px #FF7B00;
            }
            .diagonal-stripes {
                background-image: repeating-linear-gradient(45deg, rgba(11, 29, 51, 0.05) 0, rgba(11, 29, 51, 0.05) 10px, transparent 10px, transparent 20px);
            }
            .bw-overlay {
                filter: grayscale(1) contrast(1.2);
            }
        }
    </style>
</head>
<body class="bg-background-light font-dmsans text-navy">
<SiteHeader />
<section class="bg-navy relative py-24 overflow-hidden border-b-2 border-navy">
<div class="absolute inset-0 graph-paper opacity-40"></div>
<div class="max-w-7xl mx-auto px-6 relative z-10">
<div class="max-w-3xl">
<h1 class="font-bebas text-8xl text-white leading-none mb-6">PROOF, <span class="text-primary">NOT PROMISES.</span></h1>
<p class="text-concrete text-2xl font-medium leading-relaxed max-w-2xl">
                Real businesses. Real work. Real outcomes where we have the data to show them.
            </p>
</div>
</div>
</section>
<section class="bg-white border-b-2 border-navy sticky top-[76px] z-40">
<div class="max-w-7xl mx-auto px-6">
<div class="flex flex-wrap items-center">
<div class="py-6 pr-8 border-r-2 border-navy flex items-center gap-3">
<span class="material-symbols-outlined text-navy">filter_list</span>
<span class="font-bold uppercase tracking-widest text-sm">Filter Trades:</span>
</div>
<div class="flex flex-wrap flex-grow">
<button class="px-8 py-6 font-bold uppercase tracking-widest text-sm bg-navy text-white border-r-2 border-navy">All Work</button>
<button class="px-8 py-6 font-bold uppercase tracking-widest text-sm hover:bg-concrete border-r-2 border-navy transition-colors">HVAC</button>
<button class="px-8 py-6 font-bold uppercase tracking-widest text-sm hover:bg-concrete border-r-2 border-navy transition-colors">Roofing</button>
<button class="px-8 py-6 font-bold uppercase tracking-widest text-sm hover:bg-concrete border-r-2 border-navy transition-colors">Plumbing</button>
<button class="px-8 py-6 font-bold uppercase tracking-widest text-sm hover:bg-concrete border-r-2 border-navy transition-colors">Electricians</button>
<button class="px-8 py-6 font-bold uppercase tracking-widest text-sm hover:bg-concrete border-r-2 border-navy transition-colors">Solar</button>
</div>
</div>
</div>
</section>
<section class="py-24 max-w-7xl mx-auto px-6">
<div class="grid md:grid-cols-3 gap-10">
<div class="bg-white border-2 border-navy block-shadow group">
<div class="p-4 border-b-2 border-navy">
<span class="inline-block bg-primary text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest">Plumbing</span>
</div>
<div class="relative h-64 overflow-hidden border-b-2 border-navy">
<img alt="Plumbing Case Study" class="w-full h-full object-cover bw-overlay transition-transform duration-500 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQuKBUbvbDTfbjUT2ZSf2ttnd_NQ_Bnzh4GTmGjrQ_vjNFFmWfjNqvpxdtIgurxkO41Ms1uAIYKk90rC1Vg8wZ-Vk7hJTuy_n0KNBrtOgyEGvaCHAftAD4GLhzK1_HprKZVjxGAs73lhzWP46pgIY5G0_fjckrc2j0hnSSd5f0RQGEqnmrRgVcT8EL_i1raG-Su5xOM4HCjjToRVmSBmG5gyxxSZRXcQqCYz5g6HM7x8rl8InYWQDLRfxBG6B-cQN9rC6HFJfyeBo"/>
<div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
</div>
<div class="p-8">
<h3 class="font-bebas text-4xl leading-[1.1] text-navy mb-4">200% INCREASE IN CALLS IN 90 DAYS</h3>
<p class="text-sm font-bold text-navy/60 uppercase tracking-widest mb-8 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">location_on</span> Dallas, TX
                </p>
<a class="inline-block w-full bg-primary border-2 border-navy py-4 text-center font-bold text-sm uppercase tracking-widest text-white hover:bg-orange-600 transition-colors" href="#">
                    Read the Case Study
                </a>
</div>
</div>
<div class="bg-white border-2 border-navy block-shadow group">
<div class="p-4 border-b-2 border-navy">
<span class="inline-block bg-primary text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest">HVAC</span>
</div>
<div class="relative h-64 overflow-hidden border-b-2 border-navy">
<img alt="HVAC Case Study" class="w-full h-full object-cover bw-overlay transition-transform duration-500 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAp_gOZtrpGI8YFT12b7cezFByoLUrfqkjMp1MqjubNpzt7Fj_47ZKM-ju99RBfjdjSM83wzjvky4mRDEXxX9OXadl1ubIQLe9tFoI-fLMq5PhWpT7XYHhaKhsSqdaxhOpPDH7zZAsijxv_HiVqZRThBpChlmSSAX-Ge947hOrtz5U7AsVpkRToDvF-cNxE6kgpY88ZPP99ygXjrccU6zkhUF7NdPUF1Q-_M-fCsoLr5P1BUAH76YtsqX5XqtcKeUJSA0wT28J9iqo"/>
<div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
</div>
<div class="p-8">
<h3 class="font-bebas text-4xl leading-[1.1] text-navy mb-4">DOMINATING LOCAL SEARCH FOR A/C REPAIR</h3>
<p class="text-sm font-bold text-navy/60 uppercase tracking-widest mb-8 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">location_on</span> Phoenix, AZ
                </p>
<a class="inline-block w-full bg-primary border-2 border-navy py-4 text-center font-bold text-sm uppercase tracking-widest text-white hover:bg-orange-600 transition-colors" href="#">
                    Read the Case Study
                </a>
</div>
</div>
<div class="bg-white border-2 border-navy block-shadow group">
<div class="p-4 border-b-2 border-navy">
<span class="inline-block bg-primary text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest">Roofing</span>
</div>
<div class="relative h-64 overflow-hidden border-b-2 border-navy">
<img alt="Roofing Case Study" class="w-full h-full object-cover bw-overlay transition-transform duration-500 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCvzbGD4sfP-zVtaAOH-CYdMZw-j3js9me1pbdgFIVI5f4O4DC4mGrI3X4GGHAMuW4b3LsuHCKwIEn2Rciq-TMeqw6sG1dk1mrmEdzlzsHdPNWoVRHl_PV9Ayju-tyw9dext6rBFzQsZh-7lQKkk1N2M0xkmXtQPsMxx7aEep86JE811korQYvfpuMMsEJ2HVZWR0cLedUs9gYKWAUYVrFHSneMljDH8IrCTIpcyUKr8oX1tOSRLWDQCc_GNyHIt0DksyOKUlN2B9Y"/>
<div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
</div>
<div class="p-8">
<h3 class="font-bebas text-4xl leading-[1.1] text-navy mb-4">FROM ZERO TO 50 ORGANIC LEADS PER MONTH</h3>
<p class="text-sm font-bold text-navy/60 uppercase tracking-widest mb-8 flex items-center gap-2">
<span class="material-symbols-outlined text-sm">location_on</span> Nashville, TN
                </p>
<a class="inline-block w-full bg-primary border-2 border-navy py-4 text-center font-bold text-sm uppercase tracking-widest text-white hover:bg-orange-600 transition-colors" href="#">
                    Read the Case Study
                </a>
</div>
</div>
</div>
</section>
<section class="bg-concrete py-24 border-y-2 border-navy">
<div class="max-w-7xl mx-auto px-6">
<div class="mb-12">
<h2 class="font-bebas text-6xl text-navy">OUR REPORTING DEPTH</h2>
<div class="w-32 h-2 bg-primary mt-4"></div>
</div>
<div class="grid lg:grid-cols-3 gap-0 border-2 border-navy bg-white">
<div class="p-12 border-r-2 border-navy diagonal-stripes">
<div class="flex items-center gap-4 mb-6">
<span class="w-12 h-12 bg-navy text-white font-bebas text-2xl flex items-center justify-center">01</span>
<h4 class="font-bold text-xl uppercase tracking-wider">STARTING POINT</h4>
</div>
<p class="text-slate-600 leading-relaxed">
                    We dig deep into the initial metrics: monthly call volume, current keyword rankings, and site conversion rates before we touched a single line of code.
                </p>
</div>
<div class="p-12 border-r-2 border-navy">
<div class="flex items-center gap-4 mb-6">
<span class="w-12 h-12 bg-primary text-white font-bebas text-2xl flex items-center justify-center">02</span>
<h4 class="font-bold text-xl uppercase tracking-wider">WHAT WE CHANGED</h4>
</div>
<p class="text-slate-600 leading-relaxed">
                    A technical breakdown of the strategy. From custom UI builds to aggressive Local SEO map-pack optimization. We show exactly what worked.
                </p>
</div>
<div class="p-12 bg-navy text-white">
<div class="flex items-center gap-4 mb-6">
<span class="w-12 h-12 bg-white text-navy font-bebas text-2xl flex items-center justify-center">03</span>
<h4 class="font-bold text-xl uppercase tracking-wider">THE RESULTS</h4>
</div>
<p class="text-concrete/80 leading-relaxed">
                    Hard data. Call tracking records, GMB insight reports, and verified revenue growth. No vanity metrics, just bottom-line impact.
                </p>
</div>
</div>
</div>
</section>
<section class="py-24 bg-white">
<div class="max-w-5xl mx-auto px-6">
<div class="border-4 border-navy p-12 relative text-center block-shadow-orange">
<div class="absolute -top-6 left-1/2 -translate-x-1/2 bg-navy px-6 py-2 border-2 border-navy">
<span class="text-white font-bebas text-xl uppercase tracking-[.2em]">CASE STUDIES</span>
</div>
<h2 class="font-bebas text-7xl text-navy mb-8 leading-tight">READY TO BE OUR NEXT SUCCESS STORY?</h2>
<p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto font-medium">
                We're looking for partners, not just clients. If you're ready to grow your fleet, let's look at the numbers.
            </p>
<button class="bg-primary hover:bg-orange-600 text-white px-16 py-6 font-bold text-2xl uppercase tracking-widest border-2 border-navy block-shadow">
                LET'S TALK
            </button>
</div>
</div>
</section>
<SiteFooter />

</body></html>
