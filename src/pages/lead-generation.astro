---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Lead Generation | Done Deal Digital</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Work+Sans:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00",
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f6f8",
                        "background-dark": "#0B1D33",
                        "grid-gray": "rgba(255, 255, 255, 0.05)"
                    },
                    fontFamily: {
                        "display": ["Work Sans", "sans-serif"],
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "DEFAULT": "0",
                        "lg": "0",
                        "xl": "0",
                        "full": "9999px"
                    },
                    borderWidth: {
                        "3": "3px"
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image: 
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 8px 8px 0px 0px rgba(11, 29, 51, 1);
            }
            .block-shadow-orange {
                box-shadow: 8px 8px 0px 0px #FF7B00;
            }
            .blueprint-grid {
                background-size: 30px 30px;
                background-image: 
                    linear-gradient(to right, rgba(11, 29, 51, 0.08) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(11, 29, 51, 0.08) 1px, transparent 1px);
            }
            .nav-separator {
                border-right: 1px solid rgba(11, 29, 51, 0.15);
            }
        }
        .bebas-heavy {
            font-weight: 700;
            letter-spacing: 0.02em;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background-light font-dmsans text-navy antialiased">
<SiteHeader />
<section class="relative bg-navy overflow-hidden border-b-2 border-navy">
<div class="absolute inset-0 graph-paper opacity-30"></div>
<div class="max-w-7xl mx-auto px-6 lg:px-20 py-28 lg:py-48 relative z-10">
<div class="max-w-4xl">
<div class="inline-flex items-center gap-3 border-2 border-primary px-4 py-2 mb-10 bg-navy/50 backdrop-blur-sm">
<span class="w-3 h-3 bg-primary"></span>
<span class="text-white font-bebas text-2xl tracking-[.15em] uppercase">BLUE-COLLAR LEAD GENERATION</span>
</div>
<h1 class="font-bebas bebas-heavy text-7xl md:text-[140px] text-white leading-[0.85] uppercase mb-10">
                PAID ADS BUILT TO BRING IN <span class="text-primary underline decoration-8 underline-offset-8">REAL CALLS.</span>
</h1>
<p class="text-concrete text-xl md:text-2xl mb-14 leading-relaxed font-normal max-w-2xl">
                We build and manage high-intent ad campaigns that skip the window shoppers and get you in front of homeowners who need a pro right now.
            </p>
<div class="flex flex-wrap gap-6">
<button class="bg-primary hover:bg-orange-600 text-white px-12 py-7 font-bold text-xl uppercase tracking-widest transition-all border-2 border-white block-shadow-orange">
                    GET A FREE AD REVIEW
                </button>
<div class="flex items-center gap-4 px-8 py-7 border-2 border-white/20 text-white font-bold uppercase tracking-widest text-sm">
<span class="material-symbols-outlined text-primary">verified</span> No Long-Term Contracts
                </div>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="text-center mb-20">
<h2 class="font-bebas bebas-heavy text-7xl text-navy mb-4">WHEN PAID ADS MAKE SENSE</h2>
<div class="w-24 h-2 bg-primary mx-auto"></div>
</div>
<div class="grid md:grid-cols-2 gap-0 border-2 border-navy">
<div class="p-16 border-b-2 md:border-b-0 md:border-r-2 border-navy bg-white">
<div class="flex items-center gap-5 mb-12">
<div class="bg-green-600 p-2 border-2 border-navy">
<span class="material-symbols-outlined text-white text-4xl font-bold">check</span>
</div>
<h3 class="font-bebas bebas-heavy text-5xl uppercase">BEST FIT</h3>
</div>
<ul class="space-y-8">
<li class="flex items-start gap-5 group">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Answers phone quickly &amp; professionally</span>
</li>
<li class="flex items-start gap-5">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Can handle 10+ new leads per week</span>
</li>
<li class="flex items-start gap-5">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Strong local reputation &amp; reviews</span>
</li>
<li class="flex items-start gap-5">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Wants high-value install jobs</span>
</li>
</ul>
</div>
<div class="p-16 bg-concrete/20">
<div class="flex items-center gap-5 mb-12 opacity-50">
<div class="bg-red-600 p-2 border-2 border-navy">
<span class="material-symbols-outlined text-white text-4xl font-bold">close</span>
</div>
<h3 class="font-bebas bebas-heavy text-5xl uppercase">POOR FIT</h3>
</div>
<ul class="space-y-8">
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Weak offer or bad online reputation</span>
</li>
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Lets calls go to voicemail constantly</span>
</li>
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Unwilling to track ROI or lead sources</span>
</li>
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Looking for a "Magic Bullet"</span>
</li>
</ul>
</div>
</div>
</div>
</section>
<section class="bg-concrete py-32 border-y-2 border-navy">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="flex flex-col items-center text-center mb-20">
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-4">THE PROBLEM WITH MOST ADVERTISING</h2>
<div class="w-full max-w-2xl h-1 bg-navy/10 flex items-center justify-center">
<div class="bg-primary px-6 text-white font-bold uppercase tracking-tighter text-sm border-x-2 border-navy">MOST AGENCIES FAIL HERE</div>
</div>
</div>
<div class="grid md:grid-cols-3 gap-10">
<div class="bg-white p-10 border-2 border-navy relative">
<div class="absolute -top-4 left-10 bg-primary px-4 py-1 border-2 border-navy text-white font-bold text-xs">FAILURE #1</div>
<h4 class="font-bebas bebas-heavy text-4xl mb-6 mt-4">"BOOSTED" POSTS</h4>
<p class="font-medium text-slate-700 leading-relaxed">Facebook likes don't pay the bills. Paying to show your ad to random people is just throwing your hard-earned cash into a furnace. You need intent, not impressions.</p>
</div>
<div class="bg-white p-10 border-2 border-navy relative">
<div class="absolute -top-4 left-10 bg-primary px-4 py-1 border-2 border-navy text-white font-bold text-xs">FAILURE #2</div>
<h4 class="font-bebas bebas-heavy text-4xl mb-6 mt-4">LAZY LANDING PAGES</h4>
<p class="font-medium text-slate-700 leading-relaxed">Sending expensive traffic to a homepage that doesn't convert is commercial suicide. We build dedicated high-conversion pages that force the lead to take action.</p>
</div>
<div class="bg-white p-10 border-2 border-navy relative">
<div class="absolute -top-4 left-10 bg-primary px-4 py-1 border-2 border-navy text-white font-bold text-xs">FAILURE #3</div>
<h4 class="font-bebas bebas-heavy text-4xl mb-6 mt-4">ZERO TRACKING</h4>
<p class="font-medium text-slate-700 leading-relaxed">If you don't know which specific ad made the phone ring, you can't double down on what's working. We track every single click to the exact call recording.</p>
</div>
</div>
</div>
</section>
<section class="py-32 bg-background-light">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="flex items-end gap-8 mb-24">
<h2 class="font-bebas bebas-heavy text-8xl text-navy leading-none">WHAT WE<br/><span class="text-primary">MANAGE</span></h2>
<div class="flex-grow h-2 bg-navy mb-4"></div>
</div>
<div class="grid md:grid-cols-3 gap-12">
<div class="bg-white p-12 border-2 border-navy block-shadow">
<div class="bg-navy text-primary w-20 h-20 flex items-center justify-center mb-10 border-2 border-navy">
<span class="material-symbols-outlined text-5xl">search</span>
</div>
<h3 class="font-bebas bebas-heavy text-4xl mb-8 uppercase tracking-wide">GOOGLE SEARCH ADS</h3>
<ul class="space-y-5 font-bold text-sm uppercase tracking-widest border-t-2 border-navy/5 pt-10">
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Negative Keyword Lists</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Bidding Optimization</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Competitor Targeting</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Ad Copy Split-Testing</li>
</ul>
</div>
<div class="bg-white p-12 border-2 border-navy block-shadow-orange">
<div class="bg-navy text-primary w-20 h-20 flex items-center justify-center mb-10 border-2 border-navy">
<span class="material-symbols-outlined text-5xl">verified_user</span>
</div>
<h3 class="font-bebas bebas-heavy text-4xl mb-8 uppercase tracking-wide">LOCAL SERVICES ADS (LSA)</h3>
<ul class="space-y-5 font-bold text-sm uppercase tracking-widest border-t-2 border-navy/5 pt-10">
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Google Screened Setup</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Dispute Bad Leads</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Review Profile Optimization</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Weekly Ranking Audits</li>
</ul>
</div>
<div class="bg-white p-12 border-2 border-navy block-shadow">
<div class="bg-navy text-primary w-20 h-20 flex items-center justify-center mb-10 border-2 border-navy">
<span class="material-symbols-outlined text-5xl">ads_click</span>
</div>
<h3 class="font-bebas bebas-heavy text-4xl mb-8 uppercase tracking-wide">LANDING PAGES &amp; TRACKING</h3>
<ul class="space-y-5 font-bold text-sm uppercase tracking-widest border-t-2 border-navy/5 pt-10">
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Call Tracking Integration</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> A/B Split Testing</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Lightning-Fast Mobile Loads</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Dynamic Text Replacement</li>
</ul>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white border-y-2 border-navy relative overflow-hidden">
<div class="absolute inset-0 blueprint-grid opacity-60"></div>
<div class="max-w-7xl mx-auto px-6 lg:px-20 relative z-10">
<h2 class="font-bebas bebas-heavy text-7xl text-navy mb-20 text-center">HOW WE MEASURE SUCCESS</h2>
<div class="grid md:grid-cols-3 border-2 border-navy divide-y-2 md:divide-y-0 md:divide-x-2 divide-navy bg-white/90 backdrop-blur-sm">
<div class="p-16 text-center">
<p class="text-primary font-bebas text-3xl mb-4">01. THE METRIC</p>
<h4 class="font-bebas bebas-heavy text-6xl mb-6">RAW LEAD</h4>
<p class="font-bold text-slate-600 uppercase tracking-widest text-xs leading-relaxed">Every phone call and form fill tracked directly to an ad source. No guessing.</p>
</div>
<div class="p-16 text-center bg-navy text-white">
<p class="text-primary font-bebas text-3xl mb-4">02. THE FILTER</p>
<h4 class="font-bebas bebas-heavy text-6xl mb-6">QUALIFIED LEAD</h4>
<h5 class="text-primary font-bold text-xs mb-6 tracking-widest uppercase">THE QUALITY BAR</h5>
<p class="font-bold text-concrete/60 uppercase tracking-widest text-xs leading-relaxed">A lead that actually lives in your service area and needs the high-margin work you offer.</p>
</div>
<div class="p-16 text-center">
<p class="text-primary font-bebas text-3xl mb-4">03. THE BOTTOM LINE</p>
<h4 class="font-bebas bebas-heavy text-6xl mb-6">COST PER LEAD</h4>
<p class="font-bold text-slate-600 uppercase tracking-widest text-xs leading-relaxed">Total spend divided by qualified leads. This is the only number that dictates your growth speed.</p>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white">
<div class="max-w-5xl mx-auto px-6 lg:px-20">
<div class="border-4 border-navy p-12 md:p-20 bg-white block-shadow relative overflow-hidden">
<div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
<span class="material-symbols-outlined text-[120px]">assignment</span>
</div>
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-12">BUDGET &amp; EXPECTATIONS</h2>
<div class="space-y-12 font-medium text-xl leading-relaxed">
<div class="flex flex-col md:flex-row gap-8 items-start">
<div class="bg-primary p-3 border-2 border-navy shrink-0">
<span class="material-symbols-outlined text-white text-3xl">warning</span>
</div>
<div>
<p class="font-bold uppercase tracking-tight text-2xl mb-2">Small budgets can fail.</p>
<p class="text-slate-700">If you aren't willing to spend enough to get meaningful data, the search engines will never learn who your customers are. We recommend a minimum starting ad spend to ensure we're not just spinning wheels.</p>
</div>
</div>
<div class="flex flex-col md:flex-row gap-8 items-start">
<div class="bg-primary p-3 border-2 border-navy shrink-0">
<span class="material-symbols-outlined text-white text-3xl">schedule</span>
</div>
<div>
<p class="font-bold uppercase tracking-tight text-2xl mb-2">The first few weeks are for learning.</p>
<p class="text-slate-700">No campaign is perfect on day one. We spend the first 30 days aggressively pruning bad keywords and optimizing for your specific service area based on real-world search behavior.</p>
</div>
</div>
<div class="flex flex-col md:flex-row gap-8 items-start">
<div class="bg-primary p-3 border-2 border-navy shrink-0">
<span class="material-symbols-outlined text-white text-3xl">forum</span>
</div>
<div>
<p class="font-bold uppercase tracking-tight text-2xl mb-2">Communication is key.</p>
<p class="text-slate-700">We need your feedback on lead quality. If we're sending you tire-kickers, tell us immediately so we can adjust the filters. We are your partner, not just a vendor.</p>
</div>
</div>
</div>
</div>
</div>
</section>
<section class="bg-concrete py-32 border-y-2 border-navy">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
<h2 class="font-bebas bebas-heavy text-7xl text-navy">WHAT WE WILL <span class="text-red-600">NOT</span> DO</h2>
<p class="font-bold text-navy/60 uppercase tracking-[0.2em] mb-3">NO-NONSENSE GUARANTEE</p>
</div>
<div class="grid md:grid-cols-2 gap-8">
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No vanity metrics (clicks/impressions)</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No campaign launches without tracking</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No long-term contracts without results</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No outsourcing to overseas call centers</span>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white">
<div class="max-w-5xl mx-auto px-6">
<div class="border-4 border-navy p-16 md:p-24 relative text-center bg-navy text-white block-shadow-orange">
<div class="absolute inset-0 graph-paper opacity-20 pointer-events-none"></div>
<div class="relative z-10">
<h2 class="font-bebas bebas-heavy text-7xl md:text-8xl mb-10 leading-none">READY TO SEE IF PAID ADS MAKE SENSE?</h2>
<p class="text-2xl text-concrete/80 mb-14 max-w-2xl mx-auto font-medium">Get an honest review of your current ads or a custom blueprint for your first campaign. No sales pressure, just numbers.</p>
<button class="bg-primary hover:bg-orange-600 text-white px-14 py-8 font-bold text-2xl uppercase tracking-widest border-2 border-white block-shadow-orange w-full md:w-auto">
                    GET A FREE AD REVIEW
                </button>
</div>
</div>
</div>
</section>
<SiteFooter />

</body></html>
