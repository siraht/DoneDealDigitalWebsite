---
import SharedPageLayout from "../components/SharedPageLayout.astro";
---

<SharedPageLayout title="Paid Ads for Service Businesses | Done Deal Digital" bodyClass="bg-background-light font-dmsans text-navy antialiased">
    <Fragment slot="head">
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=DM+Sans:wght@400;500;700&amp;family=Work+Sans:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#FF7B00",
                        "navy": "#0B1D33",
                        "concrete": "#E2E8F0",
                        "background-light": "#f6f8fb",
                        "background-dark": "#0B1D33",
                        "grid-gray": "rgba(255, 255, 255, 0.05)"
                    },
                    fontFamily: {
                        "display": ["Work Sans", "sans-serif"],
                        "bebas": ["Bebas Neue", "cursive"],
                        "dmsans": ["DM Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "none": "0",
                        "DEFAULT": "0",
                        "lg": "0",
                        "xl": "0",
                        "full": "9999px"
                    },
                    borderWidth: {
                        "3": "3px"
                    }
                },
            },
        }
    </script>
<style type="text/tailwindcss">
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        @layer utilities {
            .graph-paper {
                background-size: 40px 40px;
                background-image: 
                    linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            }
            .block-shadow {
                box-shadow: 8px 8px 0px 0px rgba(11, 29, 51, 1);
            }
            .block-shadow-orange {
                box-shadow: 8px 8px 0px 0px #FF7B00;
            }
            .blueprint-grid {
                background-size: 30px 30px;
                background-image: 
                    linear-gradient(to right, rgba(11, 29, 51, 0.08) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(11, 29, 51, 0.08) 1px, transparent 1px);
            }
        }
        .bebas-heavy {
            font-weight: 700;
            letter-spacing: 0.02em;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</Fragment>

<section class="relative bg-navy overflow-hidden border-b-2 border-navy">
<div class="absolute inset-0 graph-paper opacity-30"></div>
<div class="max-w-7xl mx-auto px-6 lg:px-20 py-28 lg:py-48 relative z-10">
<div class="max-w-4xl">
<div class="inline-flex items-center gap-3 border-2 border-primary px-4 py-2 mb-10 bg-navy/50 backdrop-blur-sm">
<span class="w-3 h-3 bg-primary"></span>
<span class="text-white font-bebas text-2xl tracking-[.15em] uppercase">PAID ADS FOR SERVICE BUSINESSES</span>
</div>
<h1 class="font-bebas bebas-heavy text-7xl md:text-[140px] text-white leading-[0.85] uppercase mb-10">
                PAID ADS BUILT TO BRING IN <span class="text-primary underline decoration-8 underline-offset-8">REAL CALLS.</span>
            </h1>
<p class="text-concrete text-xl md:text-2xl mb-8 leading-relaxed font-normal max-w-2xl">
                We build and manage high-intent ad campaigns for service businesses that need better leads, clearer tracking, and less guesswork.
            </p>
<p class="text-concrete text-lg md:text-xl mb-8 leading-relaxed font-medium">
                We’ll say if ads are the wrong move.
            </p>
<div class="flex flex-wrap gap-6">
<button class="bg-primary hover:bg-orange-600 text-white px-12 py-7 font-bold text-xl uppercase tracking-widest transition-all border-2 border-white block-shadow-orange">
                    GET A FREE AD REVIEW
                </button>
<div class="flex items-center gap-4 px-8 py-7 border-2 border-white/20 text-white font-bold uppercase tracking-widest text-sm">
<span class="material-symbols-outlined text-primary">verified</span> No long-term contracts
                </div>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="text-center mb-20">
<h2 class="font-bebas bebas-heavy text-7xl text-navy mb-4">WHEN PAID ADS MAKE SENSE</h2>
<div class="w-24 h-2 bg-primary mx-auto"></div>
</div>
<div class="grid md:grid-cols-2 gap-0 border-2 border-navy">
<div class="p-16 border-b-2 md:border-b-0 md:border-r-2 border-navy bg-white">
<div class="flex items-center gap-5 mb-12">
<div class="bg-green-600 p-2 border-2 border-navy">
<span class="material-symbols-outlined text-white text-4xl font-bold">check</span>
</div>
<h3 class="font-bebas bebas-heavy text-5xl uppercase">BEST FIT</h3>
</div>
<ul class="space-y-8">
<li class="flex items-start gap-5 group">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Answers phone quickly and professionally</span>
</li>
<li class="flex items-start gap-5">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Has enough budget to generate data</span>
</li>
<li class="flex items-start gap-5">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Serves a defined geographic area</span>
</li>
<li class="flex items-start gap-5">
<span class="material-symbols-outlined text-green-600 mt-1 font-black">check_circle</span>
<span class="font-bold text-xl uppercase leading-tight">Can track leads and book jobs</span>
</li>
</ul>
</div>
<div class="p-16 bg-concrete/20">
<div class="flex items-center gap-5 mb-12 opacity-50">
<div class="bg-red-600 p-2 border-2 border-navy">
<span class="material-symbols-outlined text-white text-4xl font-bold">close</span>
</div>
<h3 class="font-bebas bebas-heavy text-5xl uppercase">POOR FIT</h3>
</div>
<ul class="space-y-8">
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Tiny test budgets with no room to learn</span>
</li>
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Slow follow-up or weak closing process</span>
</li>
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Bad reviews and no plan to improve them</span>
</li>
<li class="flex items-start gap-5 text-slate-500">
<span class="material-symbols-outlined text-red-600 mt-1 font-black">cancel</span>
<span class="font-bold text-xl uppercase leading-tight">Needs ads to cover a weak offer</span>
</li>
</ul>
</div>
</div>
</div>
</section>
<section class="bg-concrete py-32 border-y-2 border-navy">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="flex flex-col items-center text-center mb-20">
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-4">THE PROBLEM WITH MOST ADVERTISING</h2>
<div class="w-full max-w-2xl h-1 bg-navy/10 flex items-center justify-center">
<div class="bg-primary px-6 text-white font-bold uppercase tracking-tighter text-sm border-x-2 border-navy">MOST AGENCIES FAIL HERE</div>
</div>
</div>
<div class="grid md:grid-cols-3 gap-10">
<div class="bg-white p-10 border-2 border-navy relative">
<div class="absolute -top-4 left-10 bg-primary px-4 py-1 border-2 border-navy text-white font-bold text-xs">FAKE SIGNAL</div>
<h4 class="font-bebas bebas-heavy text-4xl mb-6 mt-4">BOOSTED POSTS</h4>
<p class="font-medium text-slate-700 leading-relaxed">Facebook likes and short-term pushes can create vanity activity, but they usually underperform for call-heavy local businesses.</p>
</div>
<div class="bg-white p-10 border-2 border-navy relative">
<div class="absolute -top-4 left-10 bg-primary px-4 py-1 border-2 border-navy text-white font-bold text-xs">WEAK START</div>
<h4 class="font-bebas bebas-heavy text-4xl mb-6 mt-4">LAZY LANDING PAGES</h4>
<p class="font-medium text-slate-700 leading-relaxed">Traffic only works when the page clearly states who you serve, what they need, and what to do next.</p>
</div>
<div class="bg-white p-10 border-2 border-navy relative">
<div class="absolute -top-4 left-10 bg-primary px-4 py-1 border-2 border-navy text-white font-bold text-xs">NO CONTROL</div>
<h4 class="font-bebas bebas-heavy text-4xl mb-6 mt-4">ZERO TRACKING</h4>
<p class="font-medium text-slate-700 leading-relaxed">Without source-to-lead tracking, you can’t tell which messages work and which one your team never follows.</p>
</div>
</div>
</div>
</section>
<section class="py-32 bg-background-light">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="flex items-end gap-8 mb-24">
<h2 class="font-bebas bebas-heavy text-8xl text-navy leading-none">WHAT WE<br/><span class="text-primary">MANAGE</span></h2>
<div class="flex-grow h-2 bg-navy mb-4"></div>
</div>
<div class="grid md:grid-cols-3 gap-12">
<div class="bg-white p-12 border-2 border-navy block-shadow">
<div class="bg-navy text-primary w-20 h-20 flex items-center justify-center mb-10 border-2 border-navy">
<span class="material-symbols-outlined text-5xl">search</span>
</div>
<h3 class="font-bebas bebas-heavy text-4xl mb-8 uppercase tracking-wide">GOOGLE SEARCH ADS</h3>
<ul class="space-y-5 font-bold text-sm uppercase tracking-widest border-t-2 border-navy/5 pt-10">
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Search campaigns and keyword structure</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Negative keyword lists and spend efficiency</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Ad-copy optimization and split testing</li>
</ul>
</div>
<div class="bg-white p-12 border-2 border-navy block-shadow-orange">
<div class="bg-navy text-primary w-20 h-20 flex items-center justify-center mb-10 border-2 border-navy">
<span class="material-symbols-outlined text-5xl">verified_user</span>
</div>
<h3 class="font-bebas bebas-heavy text-4xl mb-8 uppercase tracking-wide">LOCAL SERVICES ADS</h3>
<ul class="space-y-5 font-bold text-sm uppercase tracking-widest border-t-2 border-navy/5 pt-10">
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Profile readiness checks</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Lead category and status filters</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Bad-lead review and follow-up guidance</li>
</ul>
</div>
<div class="bg-white p-12 border-2 border-navy block-shadow">
<div class="bg-navy text-primary w-20 h-20 flex items-center justify-center mb-10 border-2 border-navy">
<span class="material-symbols-outlined text-5xl">ads_click</span>
</div>
<h3 class="font-bebas bebas-heavy text-4xl mb-8 uppercase tracking-wide">LANDING PAGES &amp; TRACKING</h3>
<ul class="space-y-5 font-bold text-sm uppercase tracking-widest border-t-2 border-navy/5 pt-10">
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Call source labeling</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Lead form and route alignment</li>
<li class="flex items-center gap-4"><span class="w-3 h-3 bg-primary"></span> Mobile-focused conversion structure</li>
</ul>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white border-y-2 border-navy relative overflow-hidden">
<div class="absolute inset-0 blueprint-grid opacity-60"></div>
<div class="max-w-7xl mx-auto px-6 lg:px-20 relative z-10">
<h2 class="font-bebas bebas-heavy text-7xl text-navy mb-20 text-center">HOW WE MEASURE SUCCESS</h2>
<div class="grid md:grid-cols-5 border-2 border-navy divide-y-2 md:divide-y-0 md:divide-x-2 divide-navy bg-white/90 backdrop-blur-sm">
<div class="p-12 text-center">
<p class="text-primary font-bebas text-3xl mb-4">01. THE METRIC</p>
<h4 class="font-bebas bebas-heavy text-5xl mb-6">RAW LEAD</h4>
<p class="font-bold text-slate-600 uppercase tracking-widest text-xs leading-relaxed">Every phone call and form fill tied to a campaign.</p>
</div>
<div class="p-12 text-center bg-navy text-white">
<p class="text-primary font-bebas text-3xl mb-4">02. THE FILTER</p>
<h4 class="font-bebas bebas-heavy text-5xl mb-6">QUALIFIED LEAD</h4>
<h5 class="text-primary font-bold text-xs mb-6 tracking-widest uppercase">QUALITY CHECK</h5>
<p class="font-bold text-concrete/70 uppercase tracking-widest text-xs leading-relaxed">Lead that is in your service area and a realistic fit.</p>
</div>
<div class="p-12 text-center">
<p class="text-primary font-bebas text-3xl mb-4">03. THE JOB</p>
<h4 class="font-bebas bebas-heavy text-5xl mb-6">BOOKED JOB</h4>
<p class="font-bold text-slate-600 uppercase tracking-widest text-xs leading-relaxed">The conversion point that matters in business outcomes.</p>
</div>
<div class="p-12 text-center bg-navy text-white">
<p class="text-primary font-bebas text-3xl mb-4">04. THE COST</p>
<h4 class="font-bebas bebas-heavy text-5xl mb-6">COST PER LEAD</h4>
<p class="font-bold text-concrete/70 uppercase tracking-widest text-xs leading-relaxed">Total spend divided by qualified leads.</p>
</div>
<div class="p-12 text-center">
<p class="text-primary font-bebas text-3xl mb-4">05. THE OUTCOME</p>
<h4 class="font-bebas bebas-heavy text-5xl mb-6">COST PER BOOKED JOB</h4>
<p class="font-bold text-slate-600 uppercase tracking-widest text-xs leading-relaxed">What a successful paid channel needs to prove.</p>
</div>
</div>
</div>
</section>
<section class="py-32 bg-background-light">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="border-4 border-navy p-12 md:p-20 bg-white block-shadow relative overflow-hidden">
<div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
<span class="material-symbols-outlined text-[120px]">assignment</span>
</div>
<h2 class="font-bebas bebas-heavy text-6xl text-navy mb-12">BUDGET &amp; EXPECTATIONS</h2>
<div class="space-y-12 font-medium text-xl leading-relaxed">
<div class="flex flex-col md:flex-row gap-8 items-start">
<div class="bg-primary p-3 border-2 border-navy shrink-0">
<span class="material-symbols-outlined text-white text-3xl">money_off</span>
</div>
<div>
<p class="font-bold uppercase tracking-tight text-2xl mb-2">Small budgets can fail.</p>
<p class="text-slate-700">If there is not enough spend to collect signal, ads become a guessing game. The strategy needs data, not just speed.</p>
</div>
</div>
<div class="flex flex-col md:flex-row gap-8 items-start">
<div class="bg-primary p-3 border-2 border-navy shrink-0">
<span class="material-symbols-outlined text-white text-3xl">schedule</span>
</div>
<div>
<p class="font-bold uppercase tracking-tight text-2xl mb-2">The first weeks are for learning.</p>
<p class="text-slate-700">Campaigns usually need a short stabilization period before volume and quality improve.</p>
</div>
</div>
<div class="flex flex-col md:flex-row gap-8 items-start">
<div class="bg-primary p-3 border-2 border-navy shrink-0">
<span class="material-symbols-outlined text-white text-3xl">tune</span>
</div>
<div>
<p class="font-bold uppercase tracking-tight text-2xl mb-2">Good campaigns improve through iteration.</p>
<p class="text-slate-700">We adjust structure and messaging after we see results and based on what your team can actually sell into.</p>
</div>
</div>
</div>
</div>
</div>
</section>
<section class="bg-concrete py-32 border-y-2 border-navy">
<div class="max-w-7xl mx-auto px-6 lg:px-20">
<div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
<h2 class="font-bebas bebas-heavy text-7xl text-navy">WHAT WE WILL <span class="text-red-600">NOT</span> DO</h2>
<p class="font-bold text-navy/60 uppercase tracking-[0.2em] mb-3">NO-NONSENSE STANDARDS</p>
</div>
<div class="grid md:grid-cols-2 gap-8">
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No boosted-post theater</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No vanity metrics focus</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No launch without tracking</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No lead guarantees</span>
</div>
<div class="flex items-center gap-8 bg-white p-8 border-2 border-navy hover:bg-slate-50 transition-colors">
<span class="material-symbols-outlined text-red-600 text-5xl shrink-0">block</span>
<span class="font-bold text-2xl uppercase tracking-tighter">No pretending every business should run ads</span>
</div>
</div>
</div>
</section>
<section class="py-32 bg-white">
<div class="max-w-5xl mx-auto px-6">
<div class="border-4 border-navy p-16 md:p-24 relative text-center bg-navy text-white block-shadow-orange">
<div class="absolute inset-0 graph-paper opacity-20 pointer-events-none"></div>
<div class="relative z-10">
<h2 class="font-bebas bebas-heavy text-7xl md:text-8xl mb-10 leading-none">WANT AN HONEST READ ON PAID ADS?</h2>
<p class="text-2xl text-concrete/80 mb-8 max-w-2xl mx-auto font-medium">
If the math works, we’ll tell you. If it doesn’t, we’ll tell you that too.
</p>
<p class="text-xl text-slate-300 mb-14 max-w-2xl mx-auto">
Get a candid review before you commit budget.
</p>
<button class="bg-primary hover:bg-orange-600 text-white px-14 py-8 font-bold text-2xl uppercase tracking-widest border-2 border-white block-shadow-orange w-full md:w-auto">
                    GET A FREE AD REVIEW
                </button>
</div>
</div>
</div>
</section>

</SharedPageLayout>
